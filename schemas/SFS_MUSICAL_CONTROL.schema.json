{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://silent-film-sonific.local/schemas/SFS_MUSICAL_CONTROL.schema.json",
  "title": "SFS_MUSICAL_CONTROL",
  "type": "object",
  "required": ["schema", "version", "timestamp_ms", "state", "controls", "events"],
  "properties": {
    "schema": {
      "const": "SFS_MUSICAL_CONTROL"
    },
    "version": {
      "type": "string"
    },
    "timestamp_ms": {
      "type": "integer",
      "minimum": 0
    },
    "state": {
      "type": "object",
      "required": ["name", "confidence", "changed", "previous"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "changed": {
          "type": "boolean"
        },
        "previous": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": true
    },
    "controls": {
      "type": "object",
      "required": ["energy", "density", "tension", "brightness", "activity", "variation"],
      "properties": {
        "energy": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "density": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "tension": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "brightness": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "activity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "variation": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "additionalProperties": true
    },
    "events": {
      "type": "object",
      "required": ["scene_change", "accent", "reset_phrase"],
      "properties": {
        "scene_change": {
          "type": "boolean"
        },
        "accent": {
          "type": "boolean"
        },
        "reset_phrase": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
