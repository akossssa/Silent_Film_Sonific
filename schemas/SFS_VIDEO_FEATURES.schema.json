{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://silent-film-sonific.local/schemas/SFS_VIDEO_FEATURES.schema.json",
  "title": "SFS_VIDEO_FEATURES",
  "type": "object",
  "required": ["schema", "version", "timestamp_ms", "source", "features"],
  "properties": {
    "schema": {
      "const": "SFS_VIDEO_FEATURES"
    },
    "version": {
      "type": "string"
    },
    "timestamp_ms": {
      "type": "integer",
      "minimum": 0
    },
    "source": {
      "type": "object",
      "required": ["type", "name", "frame", "fps"],
      "properties": {
        "type": {
          "enum": ["movie", "camera", "stream", "matrix", "texture", "unknown"]
        },
        "name": {
          "type": ["string", "null"]
        },
        "frame": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "fps": {
          "type": ["number", "null"],
          "exclusiveMinimum": 0
        },
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": true
    },
    "features": {
      "type": "object",
      "required": ["motion", "brightness", "contrast", "cut", "cut_strength"],
      "properties": {
        "motion": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "brightness": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "contrast": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "cut": {
          "type": "boolean"
        },
        "cut_strength": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "additionalProperties": true
    },
    "zones": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "motion": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "brightness": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "contrast": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
